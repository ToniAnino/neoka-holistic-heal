{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "neoka-mcp",
      "version": "0.1.0",
      "title": "Neoka - Centro de Salud Integral"
    },
    "tools": [
      {
        "name": "list_blog_posts",
        "title": "Listar artículos del blog",
        "description": "Devuelve la lista de artículos publicados en el blog de Neoka (slug, título, fecha, tiempo de lectura y meta descripción).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_blog_post",
        "title": "Obtener artículo del blog",
        "description": "Devuelve los metadatos y la URL pública de un artículo del blog de Neoka por su slug.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Slug del artículo, p. ej. 'comunicacion-asertiva-pareja'."
            }
          },
          "required": [
            "slug"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_services",
        "title": "Listar servicios",
        "description": "Devuelve los servicios ofrecidos por Neoka - Centro de Psicología, Terapia de Pareja y Coaching en Huelva.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_contact_info",
        "title": "Información de contacto",
        "description": "Devuelve el nombre, dirección, teléfono, WhatsApp, web y número de registro sanitario (NICA) de Neoka.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
